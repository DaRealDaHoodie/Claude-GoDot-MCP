[sub_resource type="Shader" id="Shader_v25gn"]
code = "shader_type spatial;
uniform vec4 albedo_color : source_color = vec4(1.0, 0.3, 0.0, 1.0);
uniform float glow_intensity : hint_range(0.0, 5.0) = 3.5;
uniform float time_scale : hint_range(0.1, 5.0) = 2.0;
uniform float dissolve : hint_range(0.0, 1.0) = 0.0;

void fragment() {
	float pulse = sin(TIME * time_scale) * 0.5 + 0.5;
	float edge = step(dissolve, UV.y);
	ALBEDO = albedo_color.rgb * edge;
	EMISSION = albedo_color.rgb * glow_intensity * pulse * edge;
	ROUGHNESS = 0.05;
	METALLIC = 0.9;
	ALPHA = edge;
}
"

